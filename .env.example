# ─── Scan tuning (all optional; sensible defaults in lib/config.ts) ───────────
# Default UI margin filter (fraction). 0.05 = 5%.
MIN_MARGIN=0.05
# Default UI confidence filter (0–1).
MATCH_THRESHOLD=0.5
# Discovery floors for the server scan (the client filters above these).
DISCOVERY_MARGIN=0
DISCOVERY_MATCH_THRESHOLD=0.45
# Max markets pulled per venue per scan. Lower this if cron/scan times out.
MAX_MARKETS=500
# Seconds to cache upstream API responses.
REVALIDATE_SECONDS=60

# ─── Persistence (REQUIRED for durable history & review on Vercel) ────────────
# Vercel KV / Upstash Redis REST credentials. Without these the app falls back
# to an ephemeral file/in-memory store and history/reviews will NOT survive
# cold starts or redeploys.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Alternatively (Upstash naming):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Local-only override for the file store directory:
# DATA_DIR=./.data

# ─── Scheduled scan auth ──────────────────────────────────────────────────────
# If set, /api/cron/scan requires "Authorization: Bearer $CRON_SECRET".
# Vercel Cron sends this automatically when configured.
CRON_SECRET=

# ─── Admin analytics gate ─────────────────────────────────────────────────────
# If set, /analytics and /api/export require ?key=$ADMIN_TOKEN (or the
# x-admin-token header). Leave unset for open access in local dev.
ADMIN_TOKEN=
