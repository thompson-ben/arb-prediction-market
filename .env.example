# ─── Persistence: Supabase (system of record) ─────────────────────────────────
# Required for all permanent data (snapshots, matches, reviews, disagreements,
# events). Without these the app still runs live scans but persists nothing.
# Find them in Supabase → Project Settings → API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=           # service role key — SERVER ONLY, never expose to the client

# ─── Scan tuning (all optional; sensible defaults in lib/config.ts) ───────────
MIN_MARGIN=0.05                      # default UI margin filter (5%)
MATCH_THRESHOLD=0.5                  # default UI confidence filter
DISCOVERY_MARGIN=0                   # server scan margin floor
DISCOVERY_MATCH_THRESHOLD=0.45       # server scan confidence floor
MAX_MARKETS=500                      # markets pulled per venue per scan
MAX_SNAPSHOTS=250                    # max opportunities snapshotted per scan (top by score)
REVALIDATE_SECONDS=60                # upstream API cache lifetime

# ─── Scheduled scan auth ──────────────────────────────────────────────────────
# If set, /api/cron/scan requires "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=

# ─── Admin analytics gate ─────────────────────────────────────────────────────
# If set, /analytics and /api/export require ?key=$ADMIN_TOKEN (or x-admin-token).
ADMIN_TOKEN=
